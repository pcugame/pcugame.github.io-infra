generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────

enum UserRole {
  USER
  OPERATOR
  ADMIN
}

enum ProjectStatus {
  PUBLISHED
  ARCHIVED
}

enum AssetKind {
  THUMBNAIL
  IMAGE
  POSTER
  GAME
  VIDEO
}

enum AssetStatus {
  READY
  DELETING
  DELETED
  FAILED
}

enum AssetPlaybackStatus {
  PENDING
  READY
  FAILED
}

enum Platform {
  PC
  MOBILE
  WEB
}

// ─── Models ───────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  googleSub String   @unique @map("google_sub")
  email     String   @default("")
  studentId String?  @unique @map("student_id")
  name      String   @default("")
  picture   String   @default("")
  role      UserRole @default(USER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions       AuthSession[]       @relation("UserSessions")
  projects       Project[]           @relation("ProjectCreator")
  memberships    ProjectMember[]     @relation("UserMemberships")
  gameUploads    GameUploadSession[] @relation("UserGameUploads")

  @@map("users")
}

model Exhibition {
  id                 Int      @id @default(autoincrement())
  year               Int
  title              String   @default("")
  isUploadEnabled    Boolean  @default(true) @map("is_upload_enabled")
  sortOrder          Int      @default(0) @map("sort_order")
  posterStorageKey   String?  @unique @map("poster_storage_key")
  posterOriginalName String   @default("") @map("poster_original_name")
  posterMimeType     String   @default("") @map("poster_mime_type")
  posterSizeBytes    BigInt   @default(0) @map("poster_size_bytes")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  projects Project[] @relation("ExhibitionProjects")

  @@unique([year, title], name: "year_title")
  @@index([sortOrder, year])
  @@map("exhibitions")
}

model Project {
  id             Int            @id @default(autoincrement())
  exhibitionId   Int            @map("exhibition_id")
  slug           String
  title          String
  summary        String         @default("")
  description    String         @default("")
  isIncomplete   Boolean        @default(false) @map("is_incomplete")
  status         ProjectStatus  @default(PUBLISHED)
  sortOrder      Int            @default(0) @map("sort_order")
  githubUrl      String         @default("") @map("github_url")
  platforms      Platform[]     @default([])
  posterAssetId  Int?           @unique @map("poster_asset_id")
  creatorId      Int            @map("creator_id")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  exhibition Exhibition @relation("ExhibitionProjects", fields: [exhibitionId], references: [id], onDelete: Cascade)
  creator    User       @relation("ProjectCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  poster     Asset?     @relation("ProjectPoster", fields: [posterAssetId], references: [id], onDelete: SetNull)

  members     ProjectMember[]      @relation("ProjectMembers")
  assets      Asset[]              @relation("ProjectAssets")
  gameUploads GameUploadSession[]  @relation("ProjectGameUploads")
  activeGameUpload GameUploadActiveSession? @relation("ProjectActiveGameUpload")

  @@unique([exhibitionId, slug], name: "project_exhibition_slug")
  @@index([exhibitionId, status, sortOrder])
  @@index([status])
  @@map("projects")
}

model ProjectMember {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  userId    Int?     @map("user_id")
  name      String
  studentId String   @default("") @map("student_id")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation("ProjectMembers", fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation("UserMemberships", fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId, sortOrder])
  @@index([userId])
  @@map("project_members")
}

model Asset {
  id                 Int                 @id @default(autoincrement())
  projectId          Int                 @map("project_id")
  kind               AssetKind
  status             AssetStatus         @default(READY)
  storageKey         String              @unique @map("storage_key")
  playbackStorageKey String?             @unique @map("playback_storage_key")
  originalName       String              @default("") @map("original_name")
  mimeType           String              @default("") @map("mime_type")
  playbackMimeType   String              @default("") @map("playback_mime_type")
  sizeBytes          BigInt              @default(0) @map("size_bytes")
  playbackSizeBytes  BigInt              @default(0) @map("playback_size_bytes")
  playbackStatus     AssetPlaybackStatus @default(PENDING) @map("playback_status")
  playbackError      String              @default("") @map("playback_error")
  isPublic           Boolean             @default(false) @map("is_public")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  project      Project  @relation("ProjectAssets", fields: [projectId], references: [id], onDelete: Cascade)
  posterOf     Project? @relation("ProjectPoster")

  @@index([projectId, kind, status])
  // Partial unique index `asset_project_game_ready_unique` on (project_id, kind)
  // WHERE status = 'READY' AND kind = 'GAME' is applied via raw SQL in
  // `migrations/20260523_allow_multiple_videos/` — Prisma can't express partial-unique
  // in the DSL. VIDEO/IMAGE etc. are intentionally excluded (projects may hold many).
  @@map("assets")
}

model AuthSession {
  id         String   @id @default(uuid())
  userId     Int      @map("user_id")
  expiresAt  DateTime @map("expires_at")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

/// Tracks a resumable chunked game-file upload session.
/// Uses S3 multipart upload — chunks go directly to object storage.
model GameUploadSession {
  id             String   @id @default(uuid())
  projectId      Int      @map("project_id")
  userId         Int      @map("user_id")
  originalName   String   @map("original_name")
  totalBytes     BigInt   @map("total_bytes")
  chunkSizeBytes Int      @map("chunk_size_bytes")
  totalChunks    Int      @map("total_chunks")
  uploadedChunks Int[]    @default([]) @map("uploaded_chunks")
  status         String   @default("PENDING") // PENDING | COMPLETING | COMPLETED | CANCELLED | FAILED
  stagingPath    String   @default("") @map("staging_path") // legacy, no longer used
  storageKey     String?  @map("storage_key") // set on completion
  s3UploadId     String?  @map("s3_upload_id")
  s3Key          String?  @map("s3_key")
  s3PartEtags    Json?    @map("s3_part_etags") // [{partNumber: Int, etag: String}]
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project Project @relation("ProjectGameUploads", fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("UserGameUploads", fields: [userId], references: [id], onDelete: Cascade)
  parts   GameUploadPart[] @relation("GameUploadSessionParts")
  activeSlot GameUploadActiveSession? @relation("GameUploadSessionActiveSlot")

  @@index([projectId])
  @@index([userId])
  @@index([status, expiresAt])
  @@map("game_upload_sessions")
}

model GameUploadPart {
  id         Int      @id @default(autoincrement())
  sessionId  String   @map("session_id")
  partNumber Int      @map("part_number")
  etag       String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  session GameUploadSession @relation("GameUploadSessionParts", fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, partNumber], name: "game_upload_part_session_part", map: "game_upload_parts_session_id_part_number_key")
  @@index([sessionId])
  @@map("game_upload_parts")
}

model GameUploadActiveSession {
  projectId Int      @id @map("project_id")
  sessionId String   @unique @map("session_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation("ProjectActiveGameUpload", fields: [projectId], references: [id], onDelete: Cascade)
  session GameUploadSession @relation("GameUploadSessionActiveSlot", fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("game_upload_active_sessions")
}

/// IP addresses permanently banned from downloading protected assets.
/// Auto-banned when download rate limit is exceeded; admins can unban.
model BannedIp {
  id        Int      @id @default(autoincrement())
  ip        String   @unique
  reason    String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("banned_ips")
}

/// S3 objects that outlived their DB record — queued by `safeDeleteObject`
/// when a sync S3 delete fails, and periodically retried by the orphan reaper.
/// A row is "pending" while resolvedAt is null; resolved rows are kept for audit.
model OrphanObject {
  id           Int       @id @default(autoincrement())
  bucket       String
  storageKey   String    @map("storage_key")
  reason       String    @default("")
  attemptCount Int       @default(0) @map("attempt_count")
  lastTriedAt  DateTime? @map("last_tried_at")
  lastError    String?   @map("last_error")
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@unique([bucket, storageKey], name: "orphan_bucket_storage_key")
  @@index([resolvedAt])
  @@map("orphan_objects")
}

/// Runtime-configurable site settings (single row, id = "default").
/// Read from memory cache; updated via admin API without server restart.
model SiteSetting {
  id              String   @id @default("default")
  maxGameFileMb   Int      @default(5120) @map("max_game_file_mb")
  maxChunkSizeMb  Int      @default(10) @map("max_chunk_size_mb")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}
