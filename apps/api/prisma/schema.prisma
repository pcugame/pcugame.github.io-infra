generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────

enum UserRole {
  USER
  OPERATOR
  ADMIN
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AssetKind {
  THUMBNAIL
  IMAGE
  POSTER
  GAME
  VIDEO
}

enum AssetStatus {
  READY
  DELETING
  DELETED
  FAILED
}

enum Platform {
  PC
  MOBILE
  WEB
}

// ─── Models ───────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  googleSub String   @unique @map("google_sub")
  email     String   @default("")
  studentId String?  @unique @map("student_id")
  name      String   @default("")
  picture   String   @default("")
  role      UserRole @default(USER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions       AuthSession[]       @relation("UserSessions")
  projects       Project[]           @relation("ProjectCreator")
  memberships    ProjectMember[]     @relation("UserMemberships")
  gameUploads    GameUploadSession[] @relation("UserGameUploads")

  @@map("users")
}

model Exhibition {
  id              Int      @id @default(autoincrement())
  year            Int
  title           String   @default("")
  isUploadEnabled Boolean  @default(true) @map("is_upload_enabled")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  projects Project[] @relation("ExhibitionProjects")

  @@unique([year, title], name: "year_title")
  @@index([sortOrder, year])
  @@map("exhibitions")
}

model Project {
  id             Int            @id @default(autoincrement())
  exhibitionId   Int            @map("exhibition_id")
  slug           String
  title          String
  summary        String         @default("")
  description    String         @default("")
  isLegacy       Boolean        @default(false) @map("is_legacy")
  status         ProjectStatus  @default(DRAFT)
  sortOrder      Int            @default(0) @map("sort_order")
  githubUrl      String         @default("") @map("github_url")
  platforms      Platform[]     @default([])
  posterAssetId  Int?           @unique @map("poster_asset_id")
  creatorId      Int            @map("creator_id")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  exhibition Exhibition @relation("ExhibitionProjects", fields: [exhibitionId], references: [id], onDelete: Cascade)
  creator    User       @relation("ProjectCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  poster     Asset?     @relation("ProjectPoster", fields: [posterAssetId], references: [id], onDelete: SetNull)

  members     ProjectMember[]      @relation("ProjectMembers")
  assets      Asset[]              @relation("ProjectAssets")
  gameUploads GameUploadSession[]  @relation("ProjectGameUploads")

  @@unique([exhibitionId, slug], name: "project_exhibition_slug")
  @@index([exhibitionId, status, sortOrder])
  @@index([status])
  @@map("projects")
}

model ProjectMember {
  id        Int      @id @default(autoincrement())
  projectId Int      @map("project_id")
  userId    Int?     @map("user_id")
  name      String
  studentId String   @default("") @map("student_id")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation("ProjectMembers", fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation("UserMemberships", fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId, sortOrder])
  @@index([userId])
  @@map("project_members")
}

model Asset {
  id          Int         @id @default(autoincrement())
  projectId   Int         @map("project_id")
  kind        AssetKind
  status      AssetStatus @default(READY)
  storageKey  String      @unique @map("storage_key")
  originalName String     @default("") @map("original_name")
  mimeType    String      @default("") @map("mime_type")
  sizeBytes   BigInt      @default(0) @map("size_bytes")
  isPublic    Boolean     @default(false) @map("is_public")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  project      Project  @relation("ProjectAssets", fields: [projectId], references: [id], onDelete: Cascade)
  posterOf     Project? @relation("ProjectPoster")

  @@index([projectId, kind, status])
  @@map("assets")
}

model AuthSession {
  id        String   @id @default(uuid())
  userId    Int      @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation("UserSessions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

/// Tracks a resumable chunked game-file upload session.
/// Uses S3 multipart upload — chunks go directly to object storage.
model GameUploadSession {
  id             String   @id @default(uuid())
  projectId      Int      @map("project_id")
  userId         Int      @map("user_id")
  originalName   String   @map("original_name")
  totalBytes     BigInt   @map("total_bytes")
  chunkSizeBytes Int      @map("chunk_size_bytes")
  totalChunks    Int      @map("total_chunks")
  uploadedChunks Int[]    @default([]) @map("uploaded_chunks")
  status         String   @default("PENDING") // PENDING | COMPLETING | COMPLETED | CANCELLED
  stagingPath    String   @default("") @map("staging_path") // legacy, no longer used
  storageKey     String?  @map("storage_key") // set on completion
  s3UploadId     String?  @map("s3_upload_id")
  s3Key          String?  @map("s3_key")
  s3PartEtags    Json?    @map("s3_part_etags") // [{partNumber: Int, etag: String}]
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  project Project @relation("ProjectGameUploads", fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation("UserGameUploads", fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([status, expiresAt])
  @@map("game_upload_sessions")
}

/// IP addresses permanently banned from downloading game files.
/// Auto-banned when download rate limit is exceeded; admins can unban.
model BannedIp {
  id        Int      @id @default(autoincrement())
  ip        String   @unique
  reason    String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("banned_ips")
}

/// Runtime-configurable site settings (single row, id = "default").
/// Read from memory cache; updated via admin API without server restart.
model SiteSetting {
  id              String   @id @default("default")
  maxGameFileMb   Int      @default(5120) @map("max_game_file_mb")
  maxChunkSizeMb  Int      @default(10) @map("max_chunk_size_mb")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}
