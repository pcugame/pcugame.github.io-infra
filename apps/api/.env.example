# Copy to .env for local API development. Do not commit .env.

# ── Runtime ─────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
TRUST_PROXY=false
SHUTDOWN_DRAIN_MS=15000

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://pcu_admin:localdev@localhost:5432/pcu_graduationproject_v2?schema=public

# ── Session cookie ──────────────────────────────────────────
# Use a unique 32+ character secret outside local development.
SESSION_SECRET=local-development-session-secret-change-me-32chars
SESSION_COOKIE_NAME=sid
SESSION_IDLE_MS=7200000
SESSION_ABSOLUTE_MS=1209600000
SESSION_TOUCH_MIN_INTERVAL_MS=300000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# ── OAuth and origins ───────────────────────────────────────
# Comma-separated Google OAuth client IDs.
GOOGLE_CLIENT_IDS=replace-with-google-web-client-id.apps.googleusercontent.com
# Enables /api/dev/auth/* routes when NODE_ENV is not production.
DEV_AUTH_ENABLED=false
# Set to g.pcu.ac.kr in production if only institution accounts may sign in.
ALLOWED_GOOGLE_HD=
CORS_ALLOWED_ORIGINS=http://localhost:5173
API_PUBLIC_URL=http://localhost:4000
WEB_PUBLIC_URL=http://localhost:5173

# ── Upload defaults ─────────────────────────────────────────
AUTO_PUBLISH_DEFAULT=false
UPLOAD_ROOT_PROTECTED=/app/storage/protected
UPLOAD_ROOT_PUBLIC=/app/storage/public

RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
RATE_LIMIT_LOGIN_MAX=20
RATE_LIMIT_LOGIN_WINDOW_MS=60000
RATE_LIMIT_SUBMIT_MAX=30
RATE_LIMIT_SUBMIT_WINDOW_MS=3600000

UPLOAD_USER_IMAGE_MAX_MB=10
UPLOAD_USER_GAME_MAX_MB=5120
UPLOAD_USER_REQUEST_MAX_MB=250
UPLOAD_USER_MAX_FILES=10
UPLOAD_PRIVILEGED_IMAGE_MAX_MB=15
UPLOAD_PRIVILEGED_GAME_MAX_MB=5120
UPLOAD_PRIVILEGED_REQUEST_MAX_MB=1200
UPLOAD_PRIVILEGED_MAX_FILES=20
UPLOAD_MAX_CONCURRENT=5
UPLOAD_CHUNKED_GAME_MAX_MB=5120
UPLOAD_CHUNK_SIZE_MB=10
UPLOAD_SESSION_TTL_MINUTES=1440

# ── Local Garage / S3-compatible storage ────────────────────
# Start apps/db first, then inspect the generated key:
# docker compose -f apps/db/docker-compose.yml exec garage garage -c /etc/garage.toml key info pcu-dev-key
S3_ENDPOINT=http://localhost:3900
S3_REGION=garage
S3_ACCESS_KEY_ID=replace-with-local-garage-key-id
S3_SECRET_ACCESS_KEY=replace-with-local-garage-secret-key
S3_BUCKET_PUBLIC=pcu-public
S3_BUCKET_PROTECTED=pcu-protected
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_TTL_SEC=60

# ── NAS export ──────────────────────────────────────────────
# Optional. Set to a mounted writable directory for admin NAS export.
# NAS_EXPORT_PATH=/mnt/nas
