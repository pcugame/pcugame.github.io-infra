{
  "name": "@pcu-graduationproject-v2/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm --prefix ../.. run build -w @pcu/contracts",
    "dev": "tsx watch src/server.ts",
    "prebuild": "npm --prefix ../.. run build -w @pcu/contracts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:import": "tsx prisma/seed.ts --import ../db/legacy-import.json",
    "lint": "eslint src prisma --max-warnings=0 && tsc --noEmit",
    "architecture": "depcruise --config .dependency-cruiser.cjs src",
    "pretest": "npm --prefix ../.. run build -w @pcu/contracts",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/type-provider-zod": "1.0.0",
    "@pcu/contracts": "*",
    "@prisma/adapter-pg": "7.9.0",
    "@prisma/client": "7.9.0",
    "@smithy/node-http-handler": "^4.6.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.1.0",
    "google-auth-library": "^10.6.2",
    "pdf-to-img": "^6.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "sharp": "^0.34.5",
    "yauzl": "^3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "^22.10.2",
    "@types/sharp": "^0.31.1",
    "@types/yauzl": "^3.4.0",
    "dependency-cruiser": "18.1.0",
    "eslint": "10.7.0",
    "prisma": "7.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "8.65.0",
    "vitest": "^4.1.0"
  }
}
