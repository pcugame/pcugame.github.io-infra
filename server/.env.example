# Copy to /srv/graduationproject_v2/.env on the server. Do not commit real values.

# Runtime binding used by server/deploy.sh
API_BIND_HOST=127.0.0.1
API_PORT=4000
LOG_LEVEL=info

# PostgreSQL container and API DATABASE_URL
POSTGRES_DB=pcu_graduationproject_v2
POSTGRES_USER=pcu_admin
POSTGRES_PASSWORD=replace-with-production-postgres-password
DATABASE_URL=postgresql://pcu_admin:replace-with-production-postgres-password@postgres:5432/pcu_graduationproject_v2?schema=public

# Session cookie
SESSION_SECRET=replace-with-32-plus-character-production-session-secret
SESSION_COOKIE_NAME=sid
SESSION_IDLE_MS=7200000
SESSION_ABSOLUTE_MS=1209600000
SESSION_TOUCH_MIN_INTERVAL_MS=300000
SHUTDOWN_DRAIN_MS=15000
COOKIE_SECURE=true
COOKIE_SAME_SITE=none

# OAuth and public origins
GOOGLE_CLIENT_IDS=replace-with-google-web-client-id.apps.googleusercontent.com
ALLOWED_GOOGLE_HD=g.pcu.ac.kr
CORS_ALLOWED_ORIGINS=https://pcugame.github.io
API_PUBLIC_URL=https://replace-with-api-host
WEB_PUBLIC_URL=https://pcugame.github.io

# Legacy local storage mount paths used by migration/export compatibility paths
STORAGE_HOST_PATH=/srv/graduationproject_v2/storage

# S3-compatible object storage
S3_ENDPOINT=https://replace-with-s3-endpoint
S3_REGION=garage
S3_ACCESS_KEY_ID=replace-with-s3-access-key-id
S3_SECRET_ACCESS_KEY=replace-with-s3-secret-access-key
S3_BUCKET_PUBLIC=pcu-public
S3_BUCKET_PROTECTED=pcu-protected
S3_FORCE_PATH_STYLE=true

# NAS export
NAS_EXPORT_HOST_PATH=/mnt/nas/pcu_storage/GraduationGame
NAS_EXPORT_PATH=/nas
